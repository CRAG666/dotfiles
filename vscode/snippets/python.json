  "pysideui": {
    "prefix": "pysui2",
    "body": [
      "import sys",
      "from PySide2.QtUiTools import QUiLoader",
      "from PySide2.QtWidgets import QApplication, Q$MainWindow",
      "from PySide2.QtCore import QFile",
      "class $name ():",
      "	def __init__(self):",
      "		super($name, self).__init__()",
      "		self.ui = QUiLoader().load(QFile(\"$uifile.ui\"))",
      "if __name__ == \"__main__\":",
      "	app = QApplication(sys.argv)",
      "	myapp=$name()",
      "	myapp.ui.show()",
      "	sys.exit(app.exec_())"
    ],
    "description": "conectar interfaz qt"
  },
