{
  // Place your snippets for python here. Each snippet is defined under a snippet name and has a prefix, body and
  // description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
  // $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
  // same ids are connected.
  // Example:
  // "Print to console": {
  // 	"prefix": "log",
  // 	"body": [
  // 		"console.log('$1');",
  // 		"$2"
  // 	],
  // 	"description": "Log output to console"
  // }
  "Print": {
    //nombre del snipet
    "prefix": "pt", //prefijo del snipet es decir como se debe escibir
    "body": "print(\"$1\")", //instuccion
    "description": "imprimir en consola" //descripcion :v
  },
  "def": {
    "prefix": "df",
    "body": [
      "def $1():",
      "    $2"
    ],
    "description": "metodo"
  },
  "def(self)": {
    "prefix": "dfs",
    "body": [
      "def $1(self):", //los $1 significan posiciones del cursor para pasar a la siguiente posicion del curzor en este caso $2 se presiona tab
      "    $2"
    ],
    "description": "metodo con parametro"
  },
  "pyqt5": {
    "prefix": "pyqt5",
    "body": [
      "import sys",
      "from PyQt5.QtWidgets import QApplication, Q$MainWindow, QWidget",
      "from $archui import Ui_$MainWindow",
      "class $name (Q$MainWindow):",
      "	def __init__(self,parent = None):",
      "		super(QWidget, self).__init__(parent)",
      "		self.ui=Ui_$MainWindow()",
      "		self.ui.setupUi(self)",
      "if __name__ == \"__main__\":",
      "	app=QApplication(sys.argv)",
      "	myapp=$name()",
      "	myapp.show()",
      "	sys.exit(app.exec_())"
    ],
    "description": "conectar interfaz qt"
  },
  "pyqt5ui": {
    "prefix": "pyqt5ui",
    "body": [
      "import sys",
      "from PyQt5.QtWidgets import QApplication, Q$MainWindow, QWidget",
      "from PyQt5 import uic",
      "class $name (Q$MainWindow):",
      "	def __init__(self,parent = None):",
      "		super(QWidget, self).__init__(parent)",
      "		uic.loadUi(\"$Ui_name.ui\", self)",
      "if __name__ == \"__main__\":",
      "	app = QApplication(sys.argv)",
      "	myapp=$name()",
      "	myapp.show()",
      "	sys.exit(app.exec_())"
    ],
    "description": "conectar interfaz qt"
  },
  "pyside": {
