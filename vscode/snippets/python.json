  "sqlite": {
    "prefix": "sqlite",
    "body": [
      "def run_query($self, query, parameter=()):",
      "    try:",
      "        with connect($self.db_name) as conn:",
      "            cursor = conn.cursor()",
      "            cursor.execute(query, parameter)",
      "            result = cursor.fetchall()",
      "            conn.commit()",
      "        return result",
      "    except IndexError as e:",
      "        print(e)",
      "    finally:",
      "        conn.close()"
    ],
    "description": "python conect database sqlite"
  },
  "BASE DIR": {
    //nombre del snipet
    "prefix": "patharch", //prefijo del snipet es decir como se debe escibir
    "body": [
      "BASE_DIR = path.dirname(path.abspath(__file__))",
      "$name = path.join(BASE_DIR, \"$namefile\")"
    ], //instuccion
    "description": "BASE DIR" //descripcion :v
  },
  "GTK3": {
    "prefix": "gtk3",
    "body": [
      "import os.path",
      "import gi",
      "gi.require_version('Gtk', '3.0')",
      "from gi.repository import Gtk",
      "class $name:",
      "    def __init__(self):",
      "        BASE_DIR = os.path.dirname(os.path.abspath(__file__))",
      "        glade = os.path.join(BASE_DIR, \"$name.glade\")",
      "        self.builder = Gtk.Builder()",
      "        self.builder.add_from_file(glade)",
      "        self.builder.connect_signals(self)",
      "        self.window =self.builder.get_object(\"$idwindows\")",
      "        self.window.connect('destroy', Gtk.main_quit)",
      "        self.window.show_all()",
      "    def init(self):",
      "        Gtk.main()",
      "    def on_window_destroy(self, *args):",
      "        Gtk.main_quit()",
      "if __name__ == \"__main__\":",
      "    app=$name()",
      "    app.init()"
    ],
    "description": "conectar a ui GTK"
  },
  "mysql": {
    "prefix": "mysql",
    "body": [
      "def run_query(query,parameter=()):",
      "	try:",
      "		conexion = pymysql.connect(host='$localhost',database='$dbname',user='$root',password='$key')",
      "		try:",
      "			with conexion.cursor() as cursor:",
      "				cursor.execute(query,parameter)",
      "				result=cursor.fetchall()",
      "			conexion.commit()",
      "			return result",
      "		finally:",
      "			conexion.close()",
      "	except (pymysql.err.OperationalError, pymysql.err.InternalError) as e:",
      "		print(\"Ocurrió un error al conectar: \", e)"
    ],
    "description": "coneccion a base de datos mysql y mariadb"
  }
}