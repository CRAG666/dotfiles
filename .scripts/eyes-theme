#!/usr/bin/env bash
# eyes-theme — switch the eyes theme between light and dark across all dotfiles.
#
# Usage: eyes-theme [--dry-run] {light|dark|toggle|auto|status}
#
# Strategy (per toggle):
#   1. Hex-swap: bulk find/replace of canonical palette hex values inside
#      files that store colors inline (terminal configs, prompt themes, …).
#   2. Symlink switch: repoint a stable symlink to the light or dark
#      variant for tools that ship two separate theme files.
#   3. Name swap: sed-based rewrite of "theme = eyes" / "eyes-dark" style
#      references in app configs.
#   4. Flag swap: toggle boolean values (delta.light, GTK prefer-dark-theme).
#   5. Daemon reload: nudge running daemons (tmux, foot, dunst, kitty,
#      gsettings, nvim sockets, zsh-patina) to pick up the new theme.
#
# Persistent state lives at $XDG_CONFIG_HOME/eyes/mode (single line).

set -euo pipefail

readonly STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/eyes"
readonly STATE_FILE="$STATE_DIR/mode"
mkdir -p "$STATE_DIR"

# ---------------------------------------------------------------------------
# Canonical palette — mirrors config/nvim/colors/eyes.lua.
# Format per entry: "slot:LIGHT_HEX:DARK_HEX" (hex without leading '#').
# ---------------------------------------------------------------------------
readonly PALETTE=(
  'bg0:add4a0:1a211a' 'bg1:a4cc98:202820'
  'bg2:9fc895:263026' 'bg3:96be8c:2d382d'
  'bg4:88b07e:3a463a' 'bg5:6a9060:536053'
  'fg0:1a1a1a:d0dcc8' 'fg1:1e2e1c:b8c8b0' 'fg2:3d5c38:9aab94'
  'gray0:486040:8a9a88' 'gray1:385030:7a8a78' 'gray2:2c4028:6a7868'
  'green0:2a5c22:7aab72' 'green1:1e4a18:88b878' 'green2:3a5030:6a9460'
  'ash:365c25:7a8c72'
  'teal:145850:5ab8a8'
  'blue0:1e4868:6a94a8' 'blue1:143c52:82aab8'
  'violet:3a2860:9090b8'
  'aqua:1a5858:6ab8b0'
  'orange0:6a3c10:b89a6a' 'orange1:7a4a18:c8a870'
  'red:7a1e18:c87868'
  'yellow:5a4808:d4b85a'
  'pink:5a2858:b890b0'
  'winterRed:d8a8a0:402828' 'winterBlue:90bcd0:223040'
  'winterGreen:94cc88:243224' 'winterYellow:d0c890:3a3420'
)

# Yazi's tmtheme.xml ports Catppuccin and uses 7 intermediate slots that
# fall between the canonical palette entries. Kept here so toggling the
# yazi file also flips these; they intentionally extend, not replace, the
# canonical palette.
readonly PALETTE_EXTRAS=(
  'yz_blue_deep:1e4a60:6aa0b0' 'yz_teal_green:206860:6cb0a4'
  'yz_off_black:222222:ddd8d0' 'yz_blue:2a5872:8aaec8'
  'yz_mauve:6a3868:b89cb8' 'yz_yellow:786018:c8b070'
  'yz_orange:8a5820:d0b078'
)

# Files where colors live inline with a '#' prefix — toggled by hex-swap.
readonly HEX_SWAP_FILES=(
  "$HOME/.tmux.conf"
  "$HOME/.profile"
  "$HOME/.zshrc"
  "$HOME/.Xresources"
  "$HOME/.config/dunst/dunstrc"
  "$HOME/.config/nushell/env.nu"
  "$HOME/.config/nushell/eyes.nu"
  "$HOME/.config/rofi/theme.rasi"
  "$HOME/.config/rofi/colors/theme.rasi"
  "$HOME/.config/rofi/colors/eyes.txt"
  "$HOME/.config/scroll/config"
  "$HOME/.config/yazi/init.lua"
  "$HOME/.config/yazi/flavors/eyes.yazi/flavor.toml"
  "$HOME/.config/yazi/flavors/eyes.yazi/tmtheme.xml"
  "$HOME/.config/tridactyl/themes/eyes.css"
)

# Files that store palette hex without a leading '#' (foot uses key=RRGGBB).
# Word-boundary anchors keep the swap from touching unrelated 6-char tokens.
readonly HEX_SWAP_FILES_BARE=(
  "$HOME/.config/foot/foot.ini"
)

# Symlinks that point to a "light" or "dark" sibling file.
# Format per entry: "symlink_path:light_target:dark_target"
# Targets are stored as relative paths (resolved by the symlink's dir).
readonly SYMLINK_SWITCHES=(
  "$HOME/.config/eza/theme.yml:eyes.yml:eyes-dark.yml"
  "$HOME/.config/zsh-patina/theme.toml:eyes-light.toml:eyes-dark.toml"
  "$HOME/.config/swaylock/config:eyes-light.conf:eyes-dark.conf"
  "$HOME/.config/hypr/colors/theme.conf:eyes-light.conf:eyes-dark.conf"
)

# Theme-name string swaps. Format: "file|sed_pattern"
# The sed pattern uses %FROM% / %TO% placeholders that are filled in with
# the source/target theme names ("eyes" or "eyes-dark") per direction.
# Single-quoted to keep '$' anchors and '"' delimiters intact.
readonly NAME_SWAPS=(
  '~/.config/starship.toml|s/^palette = "%FROM%"$/palette = "%TO%"/'
  '~/.config/atuin/config.toml|s/^name = "%FROM%"$/name = "%TO%"/'
  '~/.config/termusic/tui.toml|s/^file_name = "%FROM%"$/file_name = "%TO%"/'
  '~/.gitconfig|s/^(  features = )%FROM%$/\1%TO%/'
  '~/.zshrc|s/BAT_THEME="%FROM%"/BAT_THEME="%TO%"/g'
  '~/.config/nushell/env.nu|s/\$env\.BAT_THEME = "%FROM%"/$env.BAT_THEME = "%TO%"/'
  '~/.config/btop/btop.conf|s|/themes/%FROM%\.theme|/themes/%TO%.theme|'
  '~/.config/kitty/kitty.conf|s|colorschemes/%FROM%\.conf|colorschemes/%TO%.conf|'
  '~/.config/kitty/kitty.conf|s|colorschemes/diff-%FROM%\.conf|colorschemes/diff-%TO%.conf|'
  '~/.config/zathura/zathurarc|s|^include \./%FROM%rc$|include ./%TO%rc|'
  '~/.claude/settings.json|s|"theme": "custom:%FROM%"|"theme": "custom:%TO%"|'
)

# Boolean flag swaps. Format: "file<TAB>sed_to_dark<TAB>sed_to_light"
# Tab is the field separator because sed patterns contain '|' (regex alternation).
# Patterns match either current value so the toggle self-heals if drift.
readonly FLAG_SWAPS=(
  "$HOME/.gitconfig"$'\t'"s/^(  light = )(true|false)\$/\\1false/"$'\t'"s/^(  light = )(true|false)\$/\\1true/"
  "$HOME/.config/gtk-3.0/settings.ini"$'\t'"s/^gtk-application-prefer-dark-theme=[01]\$/gtk-application-prefer-dark-theme=1/"$'\t'"s/^gtk-application-prefer-dark-theme=[01]\$/gtk-application-prefer-dark-theme=0/"
  "$HOME/.config/gtk-4.0/settings.ini"$'\t'"s/^gtk-application-prefer-dark-theme=[01]\$/gtk-application-prefer-dark-theme=1/"$'\t'"s/^gtk-application-prefer-dark-theme=[01]\$/gtk-application-prefer-dark-theme=0/"
)

DRY_RUN=0

# ---------------------------------------------------------------------------
# Logging / shell helpers
# ---------------------------------------------------------------------------

info() { printf '%s\n' "$*"; }
warn() { printf '%s\n' "$*" >&2; }

# Expand a leading "~" to $HOME. No-op on absolute paths.
expand_home() { printf '%s' "${1/#\~/$HOME}"; }

# Convert "#RRGGBB" (or "RRGGBB") to "R;G;B" (decimal SGR triplet).
hex_to_sgr() {
  local hex="${1#\#}"
  printf '%d;%d;%d' "$((16#${hex:0:2}))" "$((16#${hex:2:2}))" "$((16#${hex:4:2}))"
}

# ---------------------------------------------------------------------------
# Mode determination
# ---------------------------------------------------------------------------

current_mode() {
  local m=""
  [[ -f "$STATE_FILE" ]] && m="$(cat "$STATE_FILE")"
  case "$m" in dark) echo dark ;; *) echo light ;; esac
}

# Daylight window: 06:00–18:59 local time → light, else dark.
auto_mode_for_now() {
  local hour
  hour="$(date +%-H)"
  ((hour >= 6 && hour < 19))   && echo light || echo dark
}

# ---------------------------------------------------------------------------
# Hex swap (canonical palette + extras)
# ---------------------------------------------------------------------------

# Emit one sed expression per line covering every palette entry plus
# extras, for the requested direction. style=hash matches "#RRGGBB" plus
# SGR triplets (38;2;R;G;B / 48;2;R;G;B); style=bare matches plain
# "RRGGBB" with word boundaries (for foot.ini-style "key=RRGGBB" lines).
build_hex_sed_script() {
  local direction="$1" style="${2:-hash}"
  local entry slot light dark from_hex to_hex from_sgr to_sgr
  for entry in "${PALETTE[@]}" "${PALETTE_EXTRAS[@]}"; do
    IFS=: read -r slot light dark <<<"$entry"
    if [[ "$direction" == "to-dark" ]]; then
      from_hex="$light"
                         to_hex="$dark"
    else
      from_hex="$dark"
                        to_hex="$light"
    fi
    if [[ "$style" == "bare" ]]; then
      printf 's/\\b%s\\b/%s/gI\n' "$from_hex" "$to_hex"
    else
      from_sgr="$(hex_to_sgr "#$from_hex")"
      to_sgr="$(hex_to_sgr "#$to_hex")"
      printf 's/#%s/#%s/gI\n' "$from_hex" "$to_hex"
      printf 's/38;2;%s/38;2;%s/g\n' "$from_sgr" "$to_sgr"
      printf 's/48;2;%s/48;2;%s/g\n' "$from_sgr" "$to_sgr"
    fi
  done
}

apply_hex_swap() {
  local direction="$1" script_hash script_bare f target
  script_hash="$(build_hex_sed_script "$direction" hash)"
  script_bare="$(build_hex_sed_script "$direction" bare)"
  for f in "${HEX_SWAP_FILES[@]}"; do
    [[ -f "$f" ]] || continue
    # Resolve through symlinks so we edit the real file in this repo.
    target="$(readlink -f "$f")"
    if ((DRY_RUN)); then
      info "  would hex-swap $target"
    else
      sed -i -E "$script_hash" "$target"
    fi
  done
  for f in "${HEX_SWAP_FILES_BARE[@]}"; do
    [[ -f "$f" ]] || continue
    target="$(readlink -f "$f")"
    if ((DRY_RUN)); then
      info "  would bare-hex-swap $target"
    else
      sed -i -E "$script_bare" "$target"
    fi
  done
}

# ---------------------------------------------------------------------------
# Symlink switch
# ---------------------------------------------------------------------------

apply_symlink_switches() {
  local mode="$1" entry symlink light dark target dir
  for entry in "${SYMLINK_SWITCHES[@]}"; do
    IFS=: read -r symlink light dark <<<"$entry"
    dir="$(dirname "$symlink")"
    [[ -d "$dir" ]] || continue
    target="$light"
                     [[ "$mode" == "dark" ]] && target="$dark"
    if ((DRY_RUN)); then
      info "  would link $symlink -> $target"
    else
      ln -sfn "$target" "$symlink"
    fi
  done
}

# ---------------------------------------------------------------------------
# Theme-name string swaps
# ---------------------------------------------------------------------------

apply_name_swaps() {
  local mode="$1" entry file pattern from to script
  if [[ "$mode" == "dark" ]]; then
    from="eyes"
                 to="eyes-dark"
  else
    from="eyes-dark"
                      to="eyes"
  fi
  for entry in "${NAME_SWAPS[@]}"; do
    file="$(expand_home "${entry%%|*}")"
    pattern="${entry#*|}"
    [[ -f "$file" ]] || continue
    script="${pattern//%FROM%/$from}"
    script="${script//%TO%/$to}"
    if ((DRY_RUN)); then
      info "  would sed on $file: $script"
    else
      sed -i -E "$script" "$file"
    fi
  done
}

# ---------------------------------------------------------------------------
# Boolean flag swaps
# ---------------------------------------------------------------------------

apply_flag_swaps() {
  local mode="$1" entry file dark_pat light_pat script
  for entry in "${FLAG_SWAPS[@]}"; do
    IFS=$'\t' read -r file dark_pat light_pat <<<"$entry"
    [[ -f "$file" ]] || continue
    script="$dark_pat"
                        [[ "$mode" == "light" ]] && script="$light_pat"
    if ((DRY_RUN)); then
      info "  would sed on $file: $script"
    else
      sed -i -E "$script" "$file"
    fi
  done
}

# ---------------------------------------------------------------------------
# Daemon reloads
# ---------------------------------------------------------------------------

reload_daemons() {
  local mode="$1"
  if ((DRY_RUN)); then
    info "  would reload running daemons"
    return
  fi

  # tmux: re-source for the running server (if any).
  if command -v tmux >/dev/null && tmux list-sessions >/dev/null 2>&1; then
    tmux source-file "$HOME/.tmux.conf" 2>/dev/null || true
  fi

  # foot: SIGUSR1 triggers config reload.
  if pgrep -x foot >/dev/null 2>&1; then
    pkill -SIGUSR1 -x foot 2>/dev/null || true
  fi

  # X resources: merge in the rewritten palette for xterm/urxvt-style apps.
  if command -v xrdb >/dev/null && [[ -f "$HOME/.Xresources" ]] \
    && [[ -n "${DISPLAY:-}" ]]; then
    xrdb -merge "$HOME/.Xresources" 2>/dev/null || true
  fi

  # hyprland: reload sources in the running compositor.
  if command -v hyprctl >/dev/null && pgrep -x Hyprland >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi

  # dunst: restart so the rewritten dunstrc takes effect.
  if pgrep -x dunst >/dev/null 2>&1; then
    pkill -x dunst 2>/dev/null || true
    sleep 0.3
    setsid dunst >/dev/null 2>&1 &
  fi

  # kitty: swap colors live if remote control is enabled.
  if command -v kitty >/dev/null && [[ -n "${KITTY_LISTEN_ON:-}" ]]; then
    local scheme="$HOME/.config/kitty/colorschemes/eyes.conf"
    [[ "$mode" == "dark" ]] && scheme="$HOME/.config/kitty/colorschemes/eyes-dark.conf"
    kitty @ set-colors --all "$scheme" 2>/dev/null || true
  fi

  # zsh-patina: restart to pick up the new theme.toml symlink.
  if command -v zsh-patina >/dev/null; then
    zsh -c "zsh-patina restart" 2>/dev/null || true
  fi

  # GTK / GNOME color-scheme hint (Thunderbird, GTK4 apps respect this).
  if command -v gsettings >/dev/null; then
    local pref="prefer-light"
                               [[ "$mode" == "dark" ]] && pref="prefer-dark"
    gsettings set org.gnome.desktop.interface color-scheme "$pref" 2>/dev/null || true
  fi

  # Running nvim instances — best-effort retheme via control sockets.
  if command -v nvim >/dev/null; then
    local sock
    for sock in /tmp/nvim-*.sock "${XDG_RUNTIME_DIR:-/tmp}"/nvim.*.0; do
      [[ -S "$sock" ]] || continue
      nvim --server "$sock" --remote-expr \
        "execute('set background=${mode}|colorscheme eyes')" \
        >/dev/null 2>&1 || true
    done
  fi

  if command -v notify-send >/dev/null; then
    notify-send -a eyes-theme "Eyes theme switched" "Now in ${mode} mode" \
      2>/dev/null || true
  fi
}

# ---------------------------------------------------------------------------
# Orchestration
# ---------------------------------------------------------------------------

set_mode() {
  local target="$1"
  local cur
  cur="$(current_mode)"

  if [[ "$cur" == "$target" ]]; then
    info "Already in $target mode."
    return 0
  fi

  info "Switching to $target..."
  apply_hex_swap         "to-${target}"
  apply_symlink_switches "$target"
  apply_name_swaps       "$target"
  apply_flag_swaps       "$target"

  ((DRY_RUN))   || echo "$target" >"$STATE_FILE"
  reload_daemons         "$target"
  info "Switched to $target mode."
}

usage() {
  cat >&2 <<EOF
Usage: $(basename "$0") [--dry-run] {light|dark|toggle|auto|status}

  light    switch to the light variant
  dark     switch to the dark variant
  toggle   flip the current variant
  auto     pick light (06:00–18:59) or dark based on local time
  status   print the current variant

  --dry-run    print what would happen without modifying any file
  -h, --help   show this help

State file: $STATE_FILE
EOF
  exit 2
}

main() {
  while [[ $# -gt 0 && "$1" == -* ]]; do
    case "$1" in
      --dry-run)
                 DRY_RUN=1
                            shift
                                  ;;
      -h | --help) usage ;;
      *)
         warn "unknown option: $1"
                                    usage
                                          ;;
    esac
  done
  case "${1:-status}" in
    light)  set_mode light ;;
    dark)   set_mode dark  ;;
    toggle)
      if [[ "$(current_mode)" == dark ]]; then
                                               set_mode light
    else
           set_mode dark
    fi
      ;;
    auto)   set_mode "$(auto_mode_for_now)" ;;
    status) current_mode ;;
    *)
       warn "unknown command: ${1:-}"
                                       usage
                                             ;;
  esac
}

main "$@"
