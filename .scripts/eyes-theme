#!/usr/bin/env bash
# eyes-theme — switch eyes theme between light and dark across all dotfiles.
#
# Usage: eyes-theme [light|dark|toggle|auto|status]
#
# Strategy: bidirectional hex-swap (no collisions between the two palettes),
# plus a handful of theme-name string swaps for tools that load themes by name.
# Sends reload signals to long-running daemons (kitty, tmux, dunst, foot).
#
# State: ~/.config/eyes/mode  (single-line "light" or "dark")
#
# Generated by Claude for /home/think-crag/Git/dotfiles.

set -euo pipefail

readonly STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/eyes"
readonly STATE_FILE="$STATE_DIR/mode"
mkdir -p "$STATE_DIR"

# Forward = light → dark.  Reverse swaps direction.  Each line: LIGHT_HEX DARK_HEX
read -r -d '' COLOR_MAP <<'EOF' || true
#1a1a1a #d0dcc8
#1e2e1c #b8c8b0
#3d5c38 #9aab94
#add4a0 #1a211a
#a4cc98 #202820
#9fc895 #263026
#96be8c #2d382d
#88b07e #3a463a
#6a9060 #536053
#486040 #8a9a88
#385030 #7a8a78
#2c4028 #6a7868
#2a5c22 #7aab72
#1e4a18 #88b878
#3a5030 #6a9460
#365c25 #7a8c72
#145850 #5ab8a8
#1e4868 #6a94a8
#143c52 #82aab8
#3a2860 #9090b8
#1a5858 #6ab8b0
#6a3c10 #b89a6a
#7a4a18 #c8a870
#7a1e18 #c87868
#5a4808 #d4b85a
#5a2858 #b890b0
#d8a8a0 #402828
#90bcd0 #223040
#94cc88 #243224
#d0c890 #3a3420
EOF

# Files that get bulk hex-swapped (light <-> dark).  Existence is checked at runtime.
HEX_SWAP_FILES=(
  "$HOME/.tmux.conf"
  "$HOME/.profile"
  "$HOME/.config/foot/foot.ini"
  "$HOME/.config/dunst/dunstrc"
  "$HOME/.zshrc"
  "$HOME/.config/nushell/env.nu"
  "$HOME/.config/nushell/eyes.nu"
  "$HOME/.config/rofi/theme.rasi"
  "$HOME/.config/rofi/colors/theme.rasi"
  "$HOME/.config/rofi/colors/eyes.txt"
  "$HOME/.config/scroll/config"
  "$HOME/.config/yazi/init.lua"
  "$HOME/.config/yazi/flavors/eyes.yazi/flavor.toml"
  "$HOME/.config/tridactyl/themes/eyes.css"
)

current_mode() {
  if [[ -f "$STATE_FILE" ]]; then
    cat "$STATE_FILE"
  else
    echo "light"
  fi
}

# Pick the mode that matches the current local time: light 06:00–18:59, else dark.
auto_mode_for_now() {
  local hour
  hour="$(date +%-H)"
  if ((hour >= 6 && hour < 19)); then
    echo "light"
  else
    echo "dark"
  fi
}

# Convert "#RRGGBB" to "R;G;B" (decimal SGR triplet)
hex_to_sgr() {
  local hex="${1#\#}"
  printf '%d;%d;%d' "$((16#${hex:0:2}))" "$((16#${hex:2:2}))" "$((16#${hex:4:2}))"
}

# Build a sed -e ...; -e ...; ... expression for one direction.
# Includes hex form (#RRGGBB) and SGR form (38;2;R;G;B and 48;2;R;G;B)
# for LS_COLORS-style entries.
build_sed_script() {
  local direction="$1"   # to-dark | to-light
  local from to from_sgr to_sgr line
  while IFS=' ' read -r from to; do
    [[ -z "$from" || -z "$to" ]] && continue
    from_sgr="$(hex_to_sgr "$from")"
    to_sgr="$(hex_to_sgr "$to")"
    if [[ "$direction" == "to-dark" ]]; then
      # hex form (case-insensitive)
      printf 's/%s/%s/gI;\n' "$from" "$to"
      # SGR fg and bg forms — anchor on "38;2;" / "48;2;" to avoid false matches
      printf 's/38;2;%s/38;2;%s/g;\n' "$from_sgr" "$to_sgr"
      printf 's/48;2;%s/48;2;%s/g;\n' "$from_sgr" "$to_sgr"
    else
      printf 's/%s/%s/gI;\n' "$to" "$from"
      printf 's/38;2;%s/38;2;%s/g;\n' "$to_sgr" "$from_sgr"
      printf 's/48;2;%s/48;2;%s/g;\n' "$to_sgr" "$from_sgr"
    fi
  done <<<"$COLOR_MAP"
}

apply_hex_swap() {
  local direction="$1"
  local script
  script="$(build_sed_script "$direction" | tr '\n' ' ')"
  for f in "${HEX_SWAP_FILES[@]}"; do
    [[ -f "$f" ]] || continue
    # Tolerate symlinks by editing the real file
    local target
    target="$(readlink -f "$f")"
    sed -i -E "$script" "$target"
  done
}

# Theme-name string swaps (palette = "eyes" ↔ "eyes-dark", etc.)
apply_name_swap() {
  local direction="$1"   # to-dark | to-light
  local from to target_mode to_lr
  if [[ "$direction" == "to-dark" ]]; then
    from="eyes"
                 to="eyes-dark"
    target_mode="dark"
    # For tools whose variant files are named eyes-light/eyes-dark:
    to_lr="eyes-dark"
  else
    from="eyes-dark"
                      to="eyes"
    target_mode="light"
    to_lr="eyes-light"
  fi

  # starship palette
  sed -i -E "s/^palette = \"${from}\"\$/palette = \"${to}\"/" \
    "$HOME/.config/starship.toml" 2>/dev/null || true

  # delta feature in .gitconfig
  sed -i -E "s/^(  features = )${from}\$/\\1${to}/" \
    "$HOME/.gitconfig" 2>/dev/null || true

  # delta light/dark flag in .gitconfig
  if [[ "$direction" == "to-dark" ]]; then
    sed -i -E 's/^(  light = )true$/\1false/' "$HOME/.gitconfig" 2>/dev/null || true
  else
    sed -i -E 's/^(  light = )false$/\1true/' "$HOME/.gitconfig" 2>/dev/null || true
  fi

  # bat (BAT_THEME env var in shell rc files — affects new shells only)
  sed -i -E "s/BAT_THEME=\"${from}\"/BAT_THEME=\"${to}\"/g" \
    "$HOME/.zshrc" 2>/dev/null || true
  sed -i -E "s/\\\$env\\.BAT_THEME = \"${from}\"/\$env.BAT_THEME = \"${to}\"/" \
    "$HOME/.config/nushell/env.nu" 2>/dev/null || true

  # btop theme path
  sed -i -E "s|/themes/${from}\\.theme|/themes/${to}.theme|" \
    "$HOME/.config/btop/btop.conf" 2>/dev/null || true

  # atuin theme name
  sed -i -E "s/^name = \"${from}\"\$/name = \"${to}\"/" \
    "$HOME/.config/atuin/config.toml" 2>/dev/null || true

  # termusic theme file_name
  sed -i -E "s/^file_name = \"${from}\"\$/file_name = \"${to}\"/" \
    "$HOME/.config/termusic/tui.toml" 2>/dev/null || true

  # kitty colorscheme includes
  sed -i -E "s|colorschemes/${from}\\.conf|colorschemes/${to}.conf|" \
    "$HOME/.config/kitty/kitty.conf" 2>/dev/null || true
  sed -i -E "s|colorschemes/diff-${from}\\.conf|colorschemes/diff-${to}.conf|" \
    "$HOME/.config/kitty/kitty.conf" 2>/dev/null || true

  # eza theme.yml symlink — repoint to the variant file
  local eza_dir="$HOME/.config/eza"
  if [[ -L "$eza_dir/theme.yml" || -f "$eza_dir/theme.yml" ]]; then
    ln -sfn "./${to}.yml" "$eza_dir/theme.yml" 2>/dev/null || true
  fi

  # qutebrowser theme.py symlink — files are eyes-light.py / eyes-dark.py
  local qb_dir="$HOME/.config/qutebrowser"
  if [[ -d "$qb_dir" ]]; then
    ln -sfn "${to_lr}.py" "$qb_dir/theme.py" 2>/dev/null || true
  fi

  # zsh-patina theme.toml symlink — files are eyes-light.toml / eyes-dark.toml.
  # config.toml is a real file referencing theme.toml via theme = "file:..."
  local zp_dir="$HOME/.config/zsh-patina"
  if [[ -d "$zp_dir" ]]; then
    ln -sfn "${to_lr}.toml" "$zp_dir/theme.toml" 2>/dev/null || true
    zsh-patina restart
  fi

  # swaylock config symlink — files are eyes-light.conf / eyes-dark.conf
  local sl_dir="$HOME/.config/swaylock"
  if [[ -d "$sl_dir" ]]; then
    ln -sfn "${to_lr}.conf" "$sl_dir/config" 2>/dev/null || true
  fi

  # hyprland colors theme.conf symlink — files are eyes-light.conf / eyes-dark.conf
  local hypr_dir="$HOME/.config/hypr/colors"
  if [[ -d "$hypr_dir" ]]; then
    ln -sfn "${to_lr}.conf" "$hypr_dir/theme.conf" 2>/dev/null || true
  fi

  # zathura include line
  sed -i -E "s|^include \\./${from}rc\$|include ./${to}rc|" \
    "$HOME/.config/zathura/zathurarc" 2>/dev/null || true

  # Claude Code custom theme (settings.json: "theme": "custom:eyes[-dark]")
  sed -i -E "s|\"theme\": \"custom:${from}\"|\"theme\": \"custom:${to}\"|" \
    "$HOME/.claude/settings.json" 2>/dev/null || true

  # GTK — toggle gtk-application-prefer-dark-theme so Adwaita loads the
  # matching variant (light for light mode, dark for dark).  No custom CSS:
  # we rely on the built-in Adwaita theme.
  local prefer_dark
  if [[ "$direction" == "to-dark" ]]; then
                                           prefer_dark=1
  else prefer_dark=0; fi
  for ini in "$HOME/.config/gtk-3.0/settings.ini" "$HOME/.config/gtk-4.0/settings.ini"; do
    [[ -f "$ini" ]] || continue
    sed -i -E "s/^gtk-application-prefer-dark-theme=[01]\$/gtk-application-prefer-dark-theme=${prefer_dark}/" "$ini"
  done
}

reload_daemons() {
  local mode="$1"

  # tmux: re-source for every running server
  if command -v tmux >/dev/null && tmux list-sessions >/dev/null 2>&1; then
    tmux source-file "$HOME/.tmux.conf" 2>/dev/null || true
  fi

  # foot: SIGUSR1 reloads config
  pkill -SIGUSR1 -x foot 2>/dev/null || true

  # hyprland: reload sources in the running compositor
  if command -v hyprctl >/dev/null && pgrep -x Hyprland >/dev/null; then
    hyprctl reload >/dev/null 2>&1 || true
  fi

  # dunst: restart
  if pgrep -x dunst >/dev/null; then
    pkill -x dunst 2>/dev/null || true
    sleep 0.3
    setsid dunst >/dev/null 2>&1 &
  fi

  # kitty: if remote control is on, swap live; otherwise new windows only
  if command -v kitty >/dev/null && [[ -n "${KITTY_LISTEN_ON:-}" ]]; then
    kitty @ set-colors --all \
      "$HOME/.config/kitty/colorschemes/eyes${mode:+-dark}.conf" 2>/dev/null ||
         true
  fi

  # GTK color-scheme hint (Thunderbird, GTK4 apps respect this)
  if command -v gsettings >/dev/null; then
    if [[ "$mode" == "dark" ]]; then
      gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' \
        2>/dev/null || true
    else
      gsettings set org.gnome.desktop.interface color-scheme 'prefer-light' \
        2>/dev/null || true
    fi
  fi

  # nvim running sockets — best-effort
  for sock in /tmp/nvim-*.sock "$XDG_RUNTIME_DIR"/nvim.*.0; do
    [[ -S "$sock" ]] || continue
    if command -v nvim >/dev/null; then
      nvim --server "$sock" --remote-expr \
        "execute('set background=${mode}|colorscheme eyes')" \
        >/dev/null 2>&1 || true
    fi
  done

  # Notify
  if command -v notify-send >/dev/null; then
    notify-send -a "eyes-theme" "Eyes theme switched" "Now in ${mode} mode" \
      2>/dev/null || true
  fi
}

set_mode() {
  local target="$1"
  local cur
  cur="$(current_mode)"

  if [[ "$cur" == "$target" ]]; then
    echo "Already in $target mode."
    return 0
  fi

  if [[ "$target" == "dark" ]]; then
    apply_hex_swap "to-dark"
    apply_name_swap "to-dark"
  else
    apply_hex_swap "to-light"
    apply_name_swap "to-light"
  fi

  echo "$target" >"$STATE_FILE"
  reload_daemons "$target"
  echo "Switched to $target mode."
}

main() {
  case "${1:-status}" in
    light) set_mode "light" ;;
    dark)  set_mode "dark"  ;;
    toggle)
      if [[ "$(current_mode)" == "dark" ]]; then
        set_mode "light"
    else
        set_mode "dark"
    fi
      ;;
    auto)  set_mode "$(auto_mode_for_now)" ;;
    status) echo "$(current_mode)" ;;
    *)
      echo "usage: $(basename "$0") [light|dark|toggle|auto|status]" >&2
      exit 2
      ;;
  esac
}

main "$@"
