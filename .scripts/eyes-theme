#!/usr/bin/env bash

set -euo pipefail

readonly STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/eyes"
readonly STATE_FILE="$STATE_DIR/mode"
mkdir -p "$STATE_DIR"

readonly DOTFILES_DIR="$(cd -- "$(dirname -- "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
readonly CLAUDE_THEME_SRC_DIR="$DOTFILES_DIR/themes/claude"
readonly OPENCODE_THEME_SRC_DIR="$DOTFILES_DIR/themes/opencode"

readonly PALETTE=(
  'bg0:add4a0:1a211a' 'bg1:a4cc98:202820'
  'bg2:9fc895:263026' 'bg3:96be8c:2d382d'
  'bg4:88b07e:3a463a' 'bg5:6a9060:536053'
  'fg0:1a1a1a:d0dcc8' 'fg1:1e2e1c:b8c8b0' 'fg2:3d5c38:9aab94'
  'gray0:486040:8a9a88' 'gray1:385030:7a8a78' 'gray2:2c4028:6a7868'
  'green0:2a5c22:7aab72' 'green1:1e4a18:88b878' 'green2:3a5030:6a9460'
  'ash:365c25:7a8c72'
  'teal:145850:5ab8a8'
  'blue0:1e4868:6a94a8' 'blue1:143c52:82aab8'
  'violet:3a2860:9090b8'
  'aqua:1a5858:6ab8b0'
  'orange0:6a3c10:b89a6a' 'orange1:7a4a18:c8a870'
  'red:7a1e18:c87868'
  'yellow:5a4808:d4b85a'
  'pink:5a2858:b890b0'
  'winterRed:d8a8a0:402828' 'winterBlue:90bcd0:223040'
  'winterGreen:94cc88:243224' 'winterYellow:d0c890:3a3420'
)

readonly PALETTE_EXTRAS=(
  'yz_blue_deep:1e4a60:6aa0b0' 'yz_teal_green:206860:6cb0a4'
  'yz_off_black:222222:ddd8d0' 'yz_blue:2a5872:8aaec8'
  'yz_mauve:6a3868:b89cb8' 'yz_yellow:786018:c8b070'
  'yz_orange:8a5820:d0b078'
)

readonly SWITCHES=(
  # -- Group A: pre-existing variant pairs (pointer was a tracked symlink) --
  'config/eza/theme.yml|eyes.yml|eyes-dark.yml'
  'config/zsh-patina/theme.toml|eyes-light.toml|eyes-dark.toml'
  'config/swaylock/config|eyes-light.conf|eyes-dark.conf'
  'config/hypr/colors/theme.conf|eyes-light.conf|eyes-dark.conf'
  # -- Group B: config references a theme by name; pointer is a fixed name --
  'config/btop/themes/eyes-active.theme|eyes.theme|eyes-dark.theme'
  'config/kitty/colorschemes/eyes-active.conf|eyes.conf|eyes-dark.conf'
  'config/kitty/colorschemes/diff-eyes-active.conf|diff-eyes.conf|diff-eyes-dark.conf'
  'config/atuin/themes/eyes-active.toml|eyes.toml|eyes-dark.toml'
  'config/termusic/themes/eyes-active.yml|eyes.yml|eyes-dark.yml'
  'config/zathura/eyes-activerc|eyesrc|eyes-darkrc'
  # -- Group C: file with inline colors, split into light/dark variants --
  'config/foot/colors.ini|colors.eyes.ini|colors.eyes-dark.ini'
  'config/dunst/dunstrc.d/50-colors.conf|../colors.eyes.conf|../colors.eyes-dark.conf'
  '.tmux.colors.conf|.tmux.colors.eyes.conf|.tmux.colors.eyes-dark.conf'
  '.Xresources|.Xresources.eyes|.Xresources.eyes-dark'
  'config/shell/colors.env|colors.eyes.env|colors.eyes-dark.env'
  'config/scroll/colors.conf|colors.eyes.conf|colors.eyes-dark.conf'
  'config/rofi/colors/theme.rasi|eyes.rasi|eyes-dark.rasi'
  'config/rofi/colors/colors.txt|eyes.txt|eyes-dark.txt'
  'config/nushell/theme.nu|eyes.nu|eyes-dark.nu'
  'config/tridactyl/themes/theme.css|eyes.css|eyes-dark.css'
  'config/starship.toml|starship.eyes.toml|starship.eyes-dark.toml'
  'config/yazi/init.lua|init.eyes.lua|init.eyes-dark.lua'
  'config/yazi/flavors/eyes.yazi|eyes-light.yazi|eyes-dark.yazi'
  'config/termusic/tui.toml|tui.eyes.toml|tui.eyes-dark.toml'
  'config/mpv/colors.conf|colors.eyes.conf|colors.eyes-dark.conf'
  # -- Group D: hunk diff theme (TOML with inline colors; hand-tuned pair) --
  'config/hunk/config.toml|config.eyes.toml|config.eyes-dark.toml'
