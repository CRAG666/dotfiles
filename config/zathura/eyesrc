set recolor                   "true"
set recolor-lightcolor        rgba(173,212,160,1)     # c_bg0  — fondo del PDF
set recolor-darkcolor         rgba(26,26,26,1)        # c_fg0  — texto del PDF

set index-fg                  rgba(26,26,26,1)        # c_fg0
set index-bg                  rgba(173,212,160,1)     # c_bg0
set index-active-fg           rgba(173,212,160,1)     # c_bg0
set index-active-bg           rgba(30,72,104,1)       # c_blue0

set render-loading-bg         rgba(173,212,160,1)     # c_bg0
set render-loading-fg         rgba(96,136,88,1)       # c_ash

set highlight-color           rgba(136,176,126,0.45)  # c_bg4 semitransparente
set highlight-fg              rgba(26,26,26,1)        # c_fg0
set highlight-active-color    rgba(30,72,104,0.45)    # c_blue0 semitransparente

