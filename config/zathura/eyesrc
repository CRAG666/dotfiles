#
# Theme — forest green (based on #add4a0)
#

set default-fg                rgba(26,26,26,1)        # c_fg0
set default-bg                rgba(173,212,160,1)     # c_bg0

set completion-bg             rgba(106,144,96,1)     # c_bg3
set completion-fg             rgba(26,26,26,1)        # c_fg0
set completion-highlight-bg   rgba(58,40,96,1)       # c_violet
set completion-highlight-fg   rgba(173,212,160,1)     # c_bg0

set completion-group-bg       rgba(150,190,140,1)     # c_bg4
set completion-group-fg       rgba(30,46,28,1)        # c_fg1

set statusbar-fg              rgba(30,46,28,1)        # c_fg1
set statusbar-bg              rgba(159,200,149,1)     # c_bg3

set inputbar-fg               rgba(26,26,26,1)        # c_fg0
set inputbar-bg               rgba(164,204,152,1)     # c_bg1

set notification-bg           rgba(164,204,152,1)     # c_bg1
