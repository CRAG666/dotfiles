# vim:fileencoding=utf-8:ft=conf
set selection-clipboard clipboard
set smooth-scroll "true"
set guioptions none
set highlight-active-color "#C3AFF7"
set font "JetBrainsMono Nerd Font Mono Bold 14"

#colorscheme

set default-bg                  "#111416"
set default-fg                  "#E6D6AC"

set statusbar-fg                "#a7bdfb"
set statusbar-bg                "#272c38"

set inputbar-bg                 "#272c38"
set inputbar-fg                 "#BF616A"

set notification-warning-fg     "#EBCB8B"
set notification-warning-bg     "#272c38"

set highlight-color             "#81A1C1"
set highlight-active-color      "#81A1C1"

set completion-highlight-bg     "#272c38"
set completion-highlight-fg     "#BF616A"

set completion-bg               "#E6D6AC"
set completion-fg               "#20242d"

set notification-bg             "#20242d"
set notification-fg             "#E6D6AC"

set recolor-darkcolor 			"#D8DEE9"
set recolor-lightcolor          "#111416"
set recolor                     "true"

# setting recolor-keep true will keep any color your pdf has.
# if it is false, it'll just be black and white
set recolor-keephue             "true"

set adjust-open "width"

set window-title-home-tilde "true"
set statusbar-basename "true"

set window-height 760
set window-width 794
