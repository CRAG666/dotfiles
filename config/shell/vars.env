# Shared static environment variables — single source of truth.
#
# Read by:
#   - zsh     (.zshrc):  set -a; source "$HOME/Git/dotfiles/config/shell/vars.env"; set +a
#   - login   (.profile): set -a; . "$HOME/Git/dotfiles/config/shell/vars.env"; set +a
#   - nushell (env.nu):  parsed and loaded via load-env (loader block at end of env.nu)
#
# Rules so every parser agrees:
#   - One KEY="value" per line, value always double-quoted.
#   - Paths use ${HOME} / ${USER} (zsh/sh expand on source; nushell substitutes them).
#   - No cross-variable references (write the literal value).
#   - Lines starting with # and blank lines are ignored.
#
# NOT here (managed by the eyes-theme tool, which sed-rewrites them per
# light/dark toggle): the Gum/FZF color vars, BAT_THEME, LS_COLORS. They stay
# in .zshrc / env.nu / .profile so theme switching keeps working.

# --- Editor / misc ---
VISUAL="${HOME}/.local/share/bob/nvim-bin/nvim"
EDITOR="${HOME}/.local/share/bob/nvim-bin/nvim"
PYTHONSTARTUP="${HOME}/.pyrc"
MYSQL_PS1="\n \d  ﯐ "
USB="/run/media/${USER}"
PASSWORD_STORE_ENABLE_EXTENSIONS="true"
NVIM_NF="true"
DOT_DIR="${HOME}/Git/dotfiles"

# --- Writing / docs tooling ---
MARPT="${HOME}/Documentos/Proyectos/Writings/utils/marp/themes"
IEEESTL="${HOME}/Documentos/Proyectos/Writings/utils/latex/ieee.csl"
LCOLORCATPPUCCIN="${HOME}/Documentos/Proyectos/Writings/utils/latex/catppuccin"

# --- FZF (non-color) ---
FZF_DEFAULT_COMMAND="fd . --type f --hidden --follow --exclude .git --no-ignore"

# --- Dev / tooling (moved from ~/.profile) ---
_JAVA_OPTIONS="-Dawt.useSystemAAFontSettings=on -Dswing.aatext=true -Dswing.defaultlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel -Dswing.crossplatformlaf=com.sun.java.swing.plaf.gtk.GTKLookAndFeel"
DOTNET_CLI_TELEMETRY_OPTOUT="1"
LSP_USE_PLISTS="true"
WEBKIT_DISABLE_DMABUF_RENDERER="1"
CCACHE_MAXSIZE="25G"
CCACHE_COMPRESS="true"
CCACHE_COMPRESSLEVEL="1"
CCACHE_SLOPPINESS="file_macro,locale,time_macros,include_file_mtime,include_file_ctime"
CCACHE_NOHASHDIR="true"
