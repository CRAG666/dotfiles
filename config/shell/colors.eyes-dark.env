# Shared themed vars — single source of truth for the eyes palette (zsh + nushell).
#
# Read by:
#   - zsh     (.zshrc):   set -a; source "$HOME/Git/dotfiles/config/shell/colors.env"; set +a
#   - login   (.profile): set -a; . "$HOME/Git/dotfiles/config/shell/colors.env"; set +a
#   - nushell (env.nu):   parsed and loaded via load-env (loader block at end of env.nu)
#
# Same parser rules as vars.env: one KEY="value" per line, value always
# double-quoted, no line breaks inside a value, '#' only at column 0 for comments.
#
# eyes-theme rewrites this file on every light/dark toggle:
#   - the #RRGGBB / SGR (38;2;… 48;2;…) colors via its HEX_SWAP_FILES list;
#   - BAT_THEME via a NAME_SWAP entry (eyes <-> eyes-dark).
# Keep every color a literal drawn from the eyes palette (config/nvim/colors/eyes.lua).

# --- bat ---
BAT_THEME="eyes-dark"

# --- LS_COLORS — truecolor SGR codes (GNU ls, tree, fd, eza fallback, nushell) ---
LS_COLORS="di=1;38;2;106;148;168:ln=38;2;90;184;168:or=38;2;200;120;104;1:ex=1;38;2;122;171;114:fi=38;2;208;220;200:pi=38;2;184;154;106:so=38;2;184;144;176:bd=38;2;200;168;112:cd=38;2;212;184;90:do=38;2;144;144;184:su=1;38;2;138;40;32:sg=1;38;2;138;40;32:tw=38;2;208;220;200;48;2;108;144;96:ow=38;2;106;148;168;48;2;32;40;32:st=38;2;26;33;26;48;2;106;148;168:*.tar=38;2;184;144;176:*.tgz=38;2;184;144;176:*.gz=38;2;184;144;176:*.zip=38;2;184;144;176:*.7z=38;2;184;144;176:*.xz=38;2;184;144;176:*.zst=38;2;184;144;176:*.bz2=38;2;184;144;176:*.rar=38;2;184;144;176:*.jpg=38;2;184;154;106:*.jpeg=38;2;184;154;106:*.png=38;2;184;154;106:*.gif=38;2;184;154;106:*.bmp=38;2;184;154;106:*.webp=38;2;184;154;106:*.svg=38;2;184;154;106:*.mp4=38;2;200;120;104:*.mkv=38;2;200;120;104:*.webm=38;2;200;120;104:*.mov=38;2;200;120;104:*.avi=38;2;200;120;104:*.mp3=38;2;122;171;114:*.flac=38;2;122;171;114:*.wav=38;2;122;171;114:*.ogg=38;2;122;171;114:*.opus=38;2;122;171;114:*.pdf=38;2;90;184;168:*.epub=38;2;90;184;168:*.djvu=38;2;90;184;168:*.md=38;2;106;184;176:*.txt=38;2;208;220;200"

# --- FZF ---
FZF_DEFAULT_OPTS=" --prompt='ﰉ ' --pointer='ﰊ' --height 40% --reverse --bind='?:toggle-preview' --color=bg+:#3a463a,bg:#1a211a,spinner:#b890b0,hl:#c87868 --color=fg:#6a94a8,header:#c87868,info:#9090b8,pointer:#b890b0 --color=marker:#b890b0,fg+:#d0dcc8,prompt:#9090b8,hl+:#c87868"

