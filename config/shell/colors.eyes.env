# Shared themed vars — single source of truth for the eyes palette (zsh + nushell).
#
# Read by:
#   - zsh     (.zshrc):   set -a; source "$HOME/Git/dotfiles/config/shell/colors.env"; set +a
#   - login   (.profile): set -a; . "$HOME/Git/dotfiles/config/shell/colors.env"; set +a
#   - nushell (env.nu):   parsed and loaded via load-env (loader block at end of env.nu)
#
# Same parser rules as vars.env: one KEY="value" per line, value always
# double-quoted, no line breaks inside a value, '#' only at column 0 for comments.
#
# eyes-theme rewrites this file on every light/dark toggle:
#   - the #RRGGBB / SGR (38;2;… 48;2;…) colors via its HEX_SWAP_FILES list;
#   - BAT_THEME via a NAME_SWAP entry (eyes <-> eyes-dark).
# Keep every color a literal drawn from the eyes palette (config/nvim/colors/eyes.lua).

# --- bat ---
BAT_THEME="eyes"

# --- LS_COLORS — truecolor SGR codes (GNU ls, tree, fd, eza fallback, nushell) ---
LS_COLORS="di=1;38;2;30;72;104:ln=38;2;20;88;80:or=38;2;122;30;24;1:ex=1;38;2;42;92;34:fi=38;2;26;26;26:pi=38;2;106;60;16:so=38;2;90;40;88:bd=38;2;122;74;24:cd=38;2;90;72;8:do=38;2;58;40;96:su=1;38;2;138;40;32:sg=1;38;2;138;40;32:tw=38;2;26;26;26;48;2;108;144;96:ow=38;2;30;72;104;48;2;164;204;152:st=38;2;173;212;160;48;2;30;72;104:*.tar=38;2;90;40;88:*.tgz=38;2;90;40;88:*.gz=38;2;90;40;88:*.zip=38;2;90;40;88:*.7z=38;2;90;40;88:*.xz=38;2;90;40;88:*.zst=38;2;90;40;88:*.bz2=38;2;90;40;88:*.rar=38;2;90;40;88:*.jpg=38;2;106;60;16:*.jpeg=38;2;106;60;16:*.png=38;2;106;60;16:*.gif=38;2;106;60;16:*.bmp=38;2;106;60;16:*.webp=38;2;106;60;16:*.svg=38;2;106;60;16:*.mp4=38;2;122;30;24:*.mkv=38;2;122;30;24:*.webm=38;2;122;30;24:*.mov=38;2;122;30;24:*.avi=38;2;122;30;24:*.mp3=38;2;42;92;34:*.flac=38;2;42;92;34:*.wav=38;2;42;92;34:*.ogg=38;2;42;92;34:*.opus=38;2;42;92;34:*.pdf=38;2;20;88;80:*.epub=38;2;20;88;80:*.djvu=38;2;20;88;80:*.md=38;2;26;88;88:*.txt=38;2;26;26;26"

# --- FZF ---
FZF_DEFAULT_OPTS=" --prompt='ﰉ ' --pointer='ﰊ' --height 40% --reverse --bind='?:toggle-preview' --color=bg+:#88b07e,bg:#add4a0,spinner:#5a2858,hl:#7a1e18 --color=fg:#1e4868,header:#7a1e18,info:#3a2860,pointer:#5a2858 --color=marker:#5a2858,fg+:#1a1a1a,prompt:#3a2860,hl+:#7a1e18"

