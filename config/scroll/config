bindsym $mod+q kill
bindsym $mod+Shift+Backspace kill all

# Fullscreen
bindsym $mod+Shift+f fullscreen
bindsym $mod+f toggle_size this 1.0 1.0
bindsym $mod+Ctrl+f fullscreen layout
bindsym $mod+Alt+f fullscreen application
bindsym $mod+Ctrl+Alt+f fullscreen global
bindsym $mod+Ctrl+Shift+f floating toggle
bindsym $mod+Shift+T layout_transpose

mode "togglesizeh" {
