# bindsym Mod1+space exec hyprlock

# Power menu
bindsym $mod+BackSpace exec pkill rofi || $ROFI_SCRIPTS powermenu

# Clipboard
bindsym $mod+v exec pkill rofi || $ROFI_SCRIPTS clipboard
bindsym XF86Launch6 exec pkill rofi || $ROFI_SCRIPTS clipboard

# Mail
bindsym XF86Mail exec betterbird

# Web browser
bindsym XF86Search exec $BROWSER

# Launchers
