# =============================================================================
# SCREENSHOTS
# =============================================================================

set $satty swappy -f -
set $printscreen_mode 'printscreen (r:region f:full o:output w:window)'
mode $printscreen_mode {
    bindsym r exec grim -g "$(slurp -d)" - | $satty; mode default
    bindsym f exec grim - | $satty; mode default
    bindsym o exec grim -o "$(scrollmsg -t get_outputs | jq -r '.[] | select(.focused) | .name')" - | $satty; mode default
    bindsym w exec scrollmsg -t get_tree | jq -r '.. | select(.focused?) | .rect | "\(.x),\(.y) \(.width)x\(.height)"' | grim -g - - | $satty; mode default
    # The image is scaled like using fractional scaling
    #bindsym w exec grim -T "$(scrollmsg -t get_tree | jq -j '.. | select(.type?) | select(.focused).foreign_toplevel_identifier')" - | $satty; mode default

    bindsym Escape mode "default"
}
bindsym Print mode $printscreen_mode

# Control de brillo con repetición y funcional en pantalla de bloqueo
bindsym --locked XF86MonBrightnessUp exec brightnessctl s +1% && ddcutil setvcp 10 + 1
bindsym --locked XF86MonBrightnessDown exec brightnessctl s 1%- && ddcutil setvcp 10 - 1

focus_wrapping no

bindgesture swipe:4:right workspace next
bindgesture swipe:4:left workspace prev

bindgesture swipe:4:up scale_workspace overview

#
# Window rules (for_window)
#
for_window [app_id="dialog"] floating enable, resize set 80ppt 80ppt

# Picture-in-Picture (General)
for_window [title="(?i)^([Pp]icture[-\s]?[Ii]n[-\s]?[Pp]icture)(.*)$"] floating enable, sticky enable, resize set 25ppt 25ppt, move position 73ppt 72ppt

# RDP
for_window [class="sdl-freerdp3"] floating disable
for_window [class="xfreerdp"] floating disable

# Herramientas de Sistema y Control
for_window [app_id="pwvucontrol"] floating enable, resize set 70ppt 70ppt
for_window [app_id="nwg-look"] floating enable
for_window [app_id="qt5ct|qt6ct"] floating enable
for_window [app_id="nm-connection-editor"] floating enable
for_window [app_id="org.kde.polkit-kde-authentication-agent-1"] floating enable
for_window [app_id="polkit-gnome-authentication-agent-1"] floating enable

# Multimedia y Visores
for_window [app_id="vlc"] floating enable
for_window [app_id="imv"] floating enable, resize set 80ppt 80ppt
for_window [class="Spotify"] floating enable

# Diálogos y Selectores de archivos
for_window [app_id="yad|filechooser|hyprland-share-picker"] floating enable
for_window [app_id="download"] floating enable, resize set 80ppt 80ppt
for_window [title="Open File|Save File|Choose Files|Save As|Confirm to replace files"] floating enable
for_window [title="Volume Control"] floating enable, resize set 60ppt 60ppt
for_window [app_id="xdg-desktop-portal-gtk"] floating enable, resize set 60ppt 60ppt
for_window [title="File Operation Progress"] floating enable
for_window [app_id="mpv"] idle_inhibit focus
for_window [app_id="firefox"] idle_inhibit fullscreen
for_window [app_id="zen"] idle_inhibit fullscreen

# Xwayland Video Bridge
for_window [class="xwaylandvideobridge"] opacity 0, floating enable, sticky enable

# Indicadores de compartir pantalla de Firefox (al scratchpad para ocultarlos)
for_window [title="Firefox — Sharing Indicator"] move scratchpad
for_window [title="Firefox - Indicador de compartición"] move scratchpad
for_window [title="(?i).*is sharing (your screen|a window).*"] move scratchpad

