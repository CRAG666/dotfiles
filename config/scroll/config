bindsym $mod+Ctrl+Shift+s mode "togglesizev"

# Mover ventana a otro monitor
bindsym $mod+semicolon focus output right
bindsym $mod+Shift+semicolon move container to output right; focus output right

# =============================================================================
# SCRATCHPAD (equivalente a specialworkspace en Hyprland)
# =============================================================================

# SUPER+A → scratchpad general (equivale a togglespecialworkspace)
bindsym $mod+a scratchpad show
bindsym $mod+Shift+a move scratchpad

# SUPER+G → scratchpad "AI" (scroll no tiene nombres en scratchpad,
# pero puedes usar workspaces con nombre como alternativa)
bindsym $mod+g workspace AI
bindsym $mod+Shift+g move container to workspace AI; workspace AI

# =============================================================================
# MODO RESIZE (equivalente al submap resize de Hyprland)
# =============================================================================

mode "resize" {
    bindsym l resize grow   width  100px
    bindsym h resize shrink width  100px
    bindsym k resize shrink height 100px
    bindsym j resize grow   height 100px

    # También con flechas
    bindsym Right resize grow   width  100px
    bindsym Left  resize shrink width  100px
    bindsym Up    resize shrink height 100px
    bindsym Down  resize grow   height 100px

    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Control de brillo con repetición y funcional en pantalla de bloqueo
bindsym --locked XF86MonBrightnessUp exec brightnessctl s +1% && ddcutil setvcp 10 + 1
bindsym --locked XF86MonBrightnessDown exec brightnessctl s 1%- && ddcutil setvcp 10 - 1

focus_wrapping no

bindgesture swipe:4:right workspace next
bindgesture swipe:4:left workspace prev

bindgesture swipe:4:up scale_workspace overview

for_window [app_id="dialog"] floating enable, resize set 80ppt 80ppt

