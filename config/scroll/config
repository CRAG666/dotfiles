for_window [class="xfreerdp"] floating disable

# Herramientas de Sistema y Control
for_window [app_id="pwvucontrol"] floating enable, resize set 70ppt 70ppt
for_window [app_id="nwg-look"] floating enable
for_window [app_id="qt5ct|qt6ct"] floating enable
for_window [app_id="nm-connection-editor"] floating enable
for_window [app_id="org.kde.polkit-kde-authentication-agent-1"] floating enable
for_window [app_id="polkit-gnome-authentication-agent-1"] floating enable

# Multimedia y Visores
