# vim: ft=swayconfig

### Variables

# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left  H
set $down  J
set $up    K
set $right L
# Rofi / Dunst / TUI helpers
set $term kitty -1
set $ROFI_SCRIPTS ~/.config/rofi/run.sh
set $DUNST_SCRIPTS ~/.config/dunst
set $RUN_TUI_DIALOG $term --class dialog

### Startup execs

exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
exec systemctl --user start sway-session.target
exec /usr/lib/mate-polkit/polkit-mate-authentication-agent-1
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store
exec ~/.config/awww/awwwallpaper.sh
exec quickshell -d
exec ~/.scripts/cloud_mount
exec systemctl --user start podman.socket
exec ~/Git/selfhost/instances.sh
exec ~/.scripts/check_battery.sh
exec swayidle -w
exec ~/.config/scroll/brightness.sh init
exec ~/.config/scroll/brightness-hotplug.sh
exec rfkill block bluetooth

# Turn the laptop backlight off whenever the "Shenzhen KTC" monitor is detected.
exec ~/.config/scroll/ktc-brightness.sh

### Lua scripts
set $lua_scripts /home/think-crag/.config/scroll/lua

# Auto 2xN grid (tile pattern). Edit MAX_PER_COL inside the script to change
# the vertical cap per column.
lua $lua_scripts/grid_NxM.lua

# Auto-marks by app_id (firefox->b, nvim->e, yazi->f, btop->s, ...).
# Jump to them with $mod+apostrophe (rofi mark switcher).
lua $lua_scripts/auto_marks.lua

# Hide kitty when open mpv
lua $lua_scripts/swallow.lua

set $CURSORSIZE 30
exec gsettings set org.gnome.desktop.interface cursor-theme 'Adwaita'
exec gsettings set org.gnome.desktop.interface cursor-size $CURSORSIZE

exec gsettings set org.gnome.desktop.interface icon-theme 'Macjaro'
exec gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita'

exec gsettings set org.gnome.desktop.interface font-name 'SFPro Nerd Font Propo Text 14'
exec gsettings set org.gnome.desktop.interface document-font-name 'SFPro Nerd Font Propo Text 14'
exec gsettings set org.gnome.desktop.interface monospace-font-name 'SFMono Nerd Font Mono 13'
exec gsettings set org.gnome.desktop.wm.preferences titlebar-font 'SFPro Nerd Font Propo Display 15'

exec gsettings set org.gnome.desktop.interface font-antialiasing 'rgba'
exec gsettings set org.gnome.desktop.interface font-hinting 'full'
exec gsettings set org.gnome.desktop.wm.preferences button-layout :

seat seat0 xcursor_theme Adwaita $CURSORSIZE

font pango:SFPro Nerd Font Propo Display 14

