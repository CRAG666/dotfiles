#!/bin/bash
# Generate a latexdiff between two Git versions of a LaTeX file
# Usage: ./latexdiff_git.sh <file.tex> <previous-commit> [output-file.tex]

set -euo pipefail

# ─── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ─── Exit state ──────────────────────────────────────────────────────────────
EXIT_STATUS=0
TMPDIR_PATH=""

# ─── Logging helpers ─────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}ℹ ${NC}$*"; }
success() { echo -e "${GREEN}✓ ${NC}$*"; }
warn()    { echo -e "${YELLOW}⚠ ${NC}$*" >&2; }
error()   { echo -e "${RED}✗ ${NC}$*" >&2; }

usage() {
    echo ""
    echo "  Usage: $0 <file.tex> <previous-commit> [output-file.tex]"
    echo ""
    echo "  Arguments:"
    echo "    file.tex           LaTeX file to compare (relative to repo root)"
    echo "    previous-commit    Git reference (HEAD~1, abc1234, v1.0, etc.)"
    echo "    output-file        Optional. Defaults to: <basename>_diff.tex"
    echo ""
    echo "  Examples:"
    echo "    $0 document.tex HEAD~1"
    echo "    $0 chapters/intro.tex abc1234 intro_diff.tex"
    echo ""
    exit 1
}

# ─── Cleanup ─────────────────────────────────────────────────────────────────
cleanup() {
    if [[ -n "$TMPDIR_PATH" && -d "$TMPDIR_PATH" ]]; then
        rm -rf "$TMPDIR_PATH"
        if [[ "$EXIT_STATUS" -ne 0 ]]; then
            warn "Temporary files removed after error."
        fi
    fi
}

trap 'EXIT_STATUS=$?; cleanup' EXIT
trap 'EXIT_STATUS=130; exit 130' INT
trap 'EXIT_STATUS=143; exit 143' TERM

# ─── Validate arguments ──────────────────────────────────────────────────────
if [[ $# -lt 2 ]]; then
    error "Not enough arguments."
    usage
fi

FILE="$1"
COMMIT="$2"

if [[ $# -ge 3 ]]; then
    OUTPUT="$3"
else
    BASENAME=$(basename "$FILE" .tex)
    DIRNAME=$(dirname "$FILE")
    if [[ "$DIRNAME" == "." ]]; then
        OUTPUT="${BASENAME}_diff.tex"
    else
        OUTPUT="${DIRNAME}/${BASENAME}_diff.tex"
    fi
fi

# ─── Validate environment ────────────────────────────────────────────────────
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    error "Not inside a Git repository."
    exit 1
fi

if ! git rev-parse --verify "$COMMIT" &>/dev/null; then
    error "Invalid Git reference: '$COMMIT'."
    exit 1
fi

if ! git cat-file -e HEAD:"$FILE" 2>/dev/null; then
    error "File '$FILE' does not exist in HEAD."
    exit 1
fi

if ! git cat-file -e "$COMMIT":"$FILE" 2>/dev/null; then
    error "File '$FILE' does not exist in commit '$COMMIT'."
    exit 1
fi

if ! command -v latexdiff &>/dev/null; then
    error "latexdiff is not installed (or not in PATH)."
    echo "  → Debian/Ubuntu:  sudo apt install latexdiff"
    echo "  → TeX Live:       sudo apt install texlive-extra-utils"
    echo "  → macOS (brew):   brew install latexdiff"
    exit 1
fi

if [[ -f "$OUTPUT" ]]; then
    warn "Output file '$OUTPUT' already exists and will be overwritten."
fi

# ─── Core logic ──────────────────────────────────────────────────────────────
TMPDIR_PATH=$(mktemp -d ./latexdiff_tmp.XXXXXX)
CURRENT_TEX="$TMPDIR_PATH/current.tex"
BEFORE_TEX="$TMPDIR_PATH/before.tex"

COMMIT_HASH=$(git rev-parse --short "$COMMIT")
HEAD_HASH=$(git rev-parse --short HEAD)

info "Comparing $FILE"
info "  $COMMIT_HASH  →  $HEAD_HASH (HEAD)"

git show "$COMMIT":"./$FILE" >"$BEFORE_TEX"
git show HEAD:"./$FILE"      >"$CURRENT_TEX"

# Verify git show actually wrote something
if [[ ! -s "$BEFORE_TEX" ]]; then
    error "Failed to extract '$FILE' from commit '$COMMIT' (empty file)."
    exit 1
fi
if [[ ! -s "$CURRENT_TEX" ]]; then
    error "Failed to extract '$FILE' from HEAD (empty file)."
    exit 1
fi

if ! latexdiff "$BEFORE_TEX" "$CURRENT_TEX" >"$OUTPUT"; then
    error "latexdiff failed to generate the diff."
    exit 1
fi

# ─── Summary ─────────────────────────────────────────────────────────────────
ADDED=$(grep -c '\\DIFadd{' "$OUTPUT" 2>/dev/null || true)
DELETED=$(grep -c '\\DIFdel{' "$OUTPUT" 2>/dev/null || true)

success "Diff written to: $OUTPUT"
echo ""
echo -e "  ${GREEN}+${NC} Marked additions:  $ADDED"
echo -e "  ${RED}-${NC} Marked deletions:  $DELETED"
echo ""
info "To compile: pdflatex '$OUTPUT'"
