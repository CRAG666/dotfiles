#!/usr/bin/env bash
# Shim transparente para TeX Live vía podman.
#
# Ejecuta los binarios de la imagen texlive/texlive:latest como si
# estuvieran instalados nativamente, sin ensuciar el sistema.
#
# No se invoca directamente: se usa a través de symlinks con el nombre
# del binario deseado. basename "$0" decide qué ejecutar dentro del
# contenedor. Por ejemplo:
#
#   lualatex -> texlive-shim     ->  lualatex documento.tex
#   pdflatex -> texlive-shim     ->  pdflatex documento.tex
#   latexmk  -> texlive-shim     ->  latexmk -pdf -pvc documento.tex
#
# Crear un shim nuevo para cualquier otro binario de TeX Live:
#   ln -s texlive-shim NOMBRE_DEL_BINARIO

set -euo pipefail

LATEX_UTILS="$HOME/Documents/Projects/utils/latex"
IMAGE="texlive/texlive:latest"

cmd="$(basename "$0")"

if [ "$cmd" = "texlive-shim" ]; then
  cat >&2 <<'EOF'
texlive-shim no se ejecuta directamente.

Se usa a través de un symlink con el nombre del binario, p. ej.:
  ln -s texlive-shim lualatex
  lualatex documento.tex
EOF
  exit 1
fi

# -t solo si hay terminal en ambos extremos, para no romper pipes/scripts
run_flags=(--rm -i)
if [ -t 0 ] && [ -t 1 ]; then
  run_flags=(--rm -ti)
fi

# Monta el directorio actual como /work; las rutas relativas funcionan igual
# que en una instalación nativa.
mounts=(-v "$PWD:/work" -w /work)

# Expone tus paquetes/clases personales (.sty/.cls) si la carpeta existe.
if [ -d "$LATEX_UTILS" ]; then
  mounts+=(-v "$LATEX_UTILS:/latex-utils:ro" -e TEXINPUTS="/latex-utils//:")
fi

exec podman run "${run_flags[@]}" "${mounts[@]}" "$IMAGE" "$cmd" "$@"
