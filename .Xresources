! eyes (light) — sage-green theme for X11 apps (xterm, urxvt, etc.)
*background:       #add4a0
*foreground:       #1a1a1a

! black
*color0:           #1a1a1a
*color8:           #486040

! red
*color1:           #7a1e18
*color9:           #8a2820

! green
*color2:           #2a5c22
*color10:          #3a5c30

! yellow
*color3:           #5a4808
*color11:          #7a4a18

! blue
*color4:           #1e4868
*color12:          #143c52

! magenta
*color5:           #5a2858
*color13:          #3a2860

! cyan
*color6:           #145850
*color14:          #1a5858

! white
*color7:           #88b07e
*color15:          #a4cc98
