  "theme": {
    "primary":           { "light": "blue0_l",   "dark": "blue0_d"   },
    "secondary":         { "light": "blue1_l",   "dark": "blue1_d"   },
    "accent":            { "light": "aqua_l",    "dark": "aqua_d"    },
    "error":             { "light": "red_l",     "dark": "red_d"     },
    "warning":           { "light": "yellow_l",  "dark": "yellow_d"  },
    "success":           { "light": "green0_l",  "dark": "green0_d"  },
    "info":              { "light": "blue1_l",   "dark": "blue1_d"   },

    "text":              { "light": "fg1_l",     "dark": "fg1_d"     },
    "textMuted":         { "light": "fg2_l",     "dark": "fg2_d"     },

    "background":        { "light": "bg0_l",     "dark": "bg0_d"     },
    "backgroundPanel":   { "light": "bg1_l",     "dark": "bg1_d"     },
    "backgroundElement": { "light": "bg2_l",     "dark": "bg2_d"     },

    "border":            { "light": "bg4_l",     "dark": "bg4_d"     },
