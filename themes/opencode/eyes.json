    "diffAddedWordBg_l":     "#b8d8a8", "diffAddedWordBg_d":     "#4a6646",
    "diffRemovedWordBg_l":   "#e0b8a4", "diffRemovedWordBg_d":   "#714c41",
    "diffAddedDimmedBg_l":   "#cce4c0", "diffAddedDimmedBg_d":   "#28381f",
    "diffRemovedDimmedBg_l": "#e8d4c4", "diffRemovedDimmedBg_d": "#33231d"
