    "violet_l": "#3a2860", "violet_d": "#9090b8",
    "aqua_l":   "#1a5858", "aqua_d":   "#6ab8b0",
    "orange0_l":"#6a3c10", "orange0_d":"#b89a6a",
    "orange1_l":"#7a4a18", "orange1_d":"#c8a870",
    "red_l":    "#7a1e18", "red_d":    "#c87868",
    "yellow_l": "#5a4808", "yellow_d": "#d4b85a",
    "pink_l":   "#5a2858", "pink_d":   "#b890b0",

    "diffAddedBg_l":         "#e0f0d8", "diffAddedBg_d":         "#324a2e",
