    "borderSubtle":      { "light": "bg3_l",     "dark": "bg3_d"     },

    "diffAdded":              { "light": "green0_l",          "dark": "green0_d"          },
    "diffRemoved":            { "light": "red_l",             "dark": "red_d"             },
