    "diffHunkHeader":         { "light": "gray0_l",           "dark": "gray0_d"           },
    "diffHighlightAdded":     { "light": "green1_l",          "dark": "green1_d"          },
    "diffHighlightRemoved":   { "light": "red_l",             "dark": "red_d"             },
    "diffAddedBg":            { "light": "diffAddedBg_l",     "dark": "diffAddedBg_d"     },
    "diffRemovedBg":          { "light": "diffRemovedBg_l",   "dark": "diffRemovedBg_d"   },
    "diffContextBg":          { "light": "bg1_l",             "dark": "bg1_d"             },
    "diffLineNumber":         { "light": "gray2_l",           "dark": "gray2_d"           },
    "diffAddedLineNumberBg":  { "light": "diffAddedDimmedBg_l",   "dark": "diffAddedDimmedBg_d"   },
    "diffRemovedLineNumberBg":{ "light": "diffRemovedDimmedBg_l", "dark": "diffRemovedDimmedBg_d" },

    "markdownText":            { "light": "fg1_l",     "dark": "fg1_d"     },
    "markdownHeading":         { "light": "blue0_l",   "dark": "blue0_d"   },
    "markdownLink":            { "light": "blue1_l",   "dark": "blue1_d"   },
    "markdownLinkText":        { "light": "blue0_l",   "dark": "blue0_d"   },
    "markdownCode":            { "light": "green0_l",  "dark": "green0_d"  },
    "markdownBlockQuote":      { "light": "gray0_l",   "dark": "gray0_d"   },
    "markdownEmph":            { "light": "orange0_l", "dark": "orange0_d" },
    "markdownStrong":          { "light": "orange1_l", "dark": "orange1_d" },
    "markdownHorizontalRule":  { "light": "bg4_l",     "dark": "bg4_d"     },
    "markdownListItem":        { "light": "blue0_l",   "dark": "blue0_d"   },
    "markdownListEnumeration": { "light": "aqua_l",    "dark": "aqua_d"    },
    "markdownImage":           { "light": "blue1_l",   "dark": "blue1_d"   },
    "markdownImageText":       { "light": "aqua_l",    "dark": "aqua_d"    },
    "markdownCodeBlock":       { "light": "fg1_l",     "dark": "fg1_d"     },

    "syntaxComment":     { "light": "gray0_l",   "dark": "gray0_d"   },
    "syntaxKeyword":     { "light": "blue0_l",   "dark": "blue0_d"   },
    "syntaxFunction":    { "light": "blue1_l",   "dark": "blue1_d"   },
    "syntaxVariable":    { "light": "aqua_l",    "dark": "aqua_d"    },
    "syntaxString":      { "light": "green1_l",  "dark": "green1_d"  },
    "syntaxNumber":      { "light": "orange0_l", "dark": "orange0_d" },
    "syntaxType":        { "light": "teal_l",    "dark": "teal_d"    },
    "syntaxOperator":    { "light": "red_l",     "dark": "red_d"     },
    "syntaxPunctuation": { "light": "fg1_l",     "dark": "fg1_d"     }
  }
}
