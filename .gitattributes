# git-crypt: secretos / datos sensibles cifrados dentro del repo
.gitconfig filter=git-crypt diff=git-crypt
config/rofi/text/bookmarks.db filter=git-crypt diff=git-crypt
config/rofi/text/notes.db filter=git-crypt diff=git-crypt

# Scripts con infraestructura interna (hosts, IP, usuario) — repo público
.scripts/vpn filter=git-crypt diff=git-crypt
.scripts/vpn-cookie filter=git-crypt diff=git-crypt
local/bin/ssh-inaoe filter=git-crypt diff=git-crypt
local/bin/rsync-inaoe filter=git-crypt diff=git-crypt
local/bin/forti-vpn filter=git-crypt diff=git-crypt

# Guardas protectoras: archivos aún no versionados que, de añadirse, deben
# cifrarse SIEMPRE (evita commitear historiales de shell en texto plano).
.zsh_history filter=git-crypt diff=git-crypt
config/nushell/history.txt filter=git-crypt diff=git-crypt
